# Large generated ML artifacts
# These are needed to run the trained app locally, but they are too large for normal GitHub.
# Share them separately, use Git LFS, or regenerate/download them after cloning.
02_src/models/
02_src/data/processed/*.npy
02_src/data/processed/*.index
02_src/data/processed/*.pkl
02_src/data/processed/*.joblib
02_src/data/processed/job_embeddings_*
02_src/data/processed/job_faiss_*

# Keep lightweight processed data and reports trackable
!02_src/data/processed/cleaned_data.csv
!02_src/data/processed/skill_cooc.json
!02_src/data/processed/skill_mappings_7b.jsonl
!02_src/data/processed/skill_mappings_32b.jsonl
!02_src/reports/recommendation_benchmark.csv
!03_assets/*.csv
!03_assets/*.png

# Accidentally duplicated nested project copies
**/Job Market Intelligence AI/

# Streamlit Space (deployed separately to Hugging Face Spaces, not part of the GitHub repo)
streamlit_space/
